# Copy to `.env` (plain text, NOT .rtf) and fill in. `.env` is gitignored.
# Attending only needs a key for RUNTIME LLM augmentation and the live demo
# performer. The deterministic core (gates, ESI, journey, replay) runs with
# no key at all.

# Anthropic API key for runtime LLM calls.
ANTHROPIC_API_KEY=

# The single model seam: screener judges AND the demo performer resolve here.
ATTENDING_MODEL=claude-opus-4-8
