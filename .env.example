# Copy to `.env` (plain text, NOT .rtf) and fill in. `.env` is gitignored.
# Attending only needs a key for RUNTIME LLM augmentation of the anchoring /
# hallucination detectors (Fable 5). The deterministic core runs with no key.

# Anthropic API key for runtime Fable 5 calls.
ANTHROPIC_API_KEY=

# Runtime model for the LLM detector hooks (routes to Anthropic client).
ATTENDING_LLM_MODEL=claude-fable-5
